Options -Indexes

# ─── Hide .php Extension from URLs ───────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Base path for the app inside the website folder
    RewriteBase /Certain_website/app.certain_company/

    # 1. Redirect: strip .php if typed directly in browser
    RewriteCond %{THE_REQUEST} \s/Certain_website/app\.certain_company/(.+?)\.php[\s?] [NC]
    RewriteRule ^ %1 [R=301,NE,L]

    # 2. Internally map clean URL to the .php file
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^\.]+)$ $1.php [NC,L]
</IfModule>
